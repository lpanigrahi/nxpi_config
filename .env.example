# =============================================================================
# .env.example — Compose INTERPOLATION values for the standalone Azure deploy.
#
# Copy to `.env` (never commit it). Docker Compose auto-loads `.env` from this
# directory and substitutes ${VAR} occurrences in docker-compose.yml. The APP
# container's runtime env comes from ./.env.app; DB/Redis/auth secrets come
# from ./secrets/*.
#
#   cp .env.example .env   # then edit  (./install.sh does this for you)
# =============================================================================

# ── Application image (pulled from the registry — never built on the VM) ─────
# Published by the app repo's CI on every push to main and on releases.
# Pin :X.Y.Z or :sha-<commit> for deterministic deploys.
APP_IMAGE=ghcr.io/lpanigrahi/nxpi_dev:latest

# Which shipped SQL artifact set to provision from (./db/<version>/). Leave
# unset to auto-derive from the APP_IMAGE tag (e.g. :1.2.0 → db/1.2.0). Set it
# explicitly when APP_IMAGE is :latest, or to pin a specific artifact version.
#DB_VERSION=1.2.0

# Public helper image that computes the admin password hash (Better Auth
# scrypt; contains no application source). Pin to the same version as the app
# for guaranteed hash-format parity.
NXPI_HASH_IMAGE=ghcr.io/lpanigrahi/nxpi-hash:latest

# ── Ingress mode ─────────────────────────────────────────────────────────────
# IP-only mode (default): leave SITE_ADDRESS unset/empty. Caddy serves plain
# HTTP on :80 at the VM's public IP — no DNS or certificates required.
# Domain mode: set SITE_ADDRESS to a hostname whose DNS A-record points at
# this VM; Caddy then auto-provisions Let's Encrypt TLS on 80/443 (open 443 in
# the NSG) and redirects HTTP→HTTPS.
#SITE_ADDRESS=your-domain.example.com

# Public base URL — Better Auth derives the trusted-origin and auth callbacks
# from THIS var. (Secure cookies are NOT derived from it: NODE_ENV=production
# forces them ON unless you set BETTER_AUTH_COOKIE_SECURE=false in ./.env.app
# — required in IP-only mode, or browsers drop the session cookie over http://
# and sign-in loops.)
#   IP-only mode:  http://<VM_PUBLIC_IP>   (+ BETTER_AUTH_COOKIE_SECURE=false)
#   Domain mode:   https://<SITE_ADDRESS>  (MUST be https with a domain)
BETTER_AUTH_URL=http://<VM_PUBLIC_IP>

# Host ports Caddy publishes. Leave at defaults on the VM; override only when
# smoke-testing the package on a workstation where 80/443 are taken.
#CADDY_HTTP_PORT=80
#CADDY_HTTPS_PORT=443

# ── First-run bootstrap (read ONLY by `--profile init run --rm bootstrap`) ───
# Super admin created on a fresh database (idempotent — adopts an existing
# admin on re-run; a re-run will NOT reset the password).
# SET SUPER_ADMIN_EMAIL to your own address. Leave SUPER_ADMIN_PASSWORD unset
# (commented) to have the bootstrap GENERATE a strong password and print it
# ONCE in its output — capture it. Setting a password here is optional.
SUPER_ADMIN_EMAIL=admin@example.com
# A password containing spaces or a '#' MUST be quoted, e.g.
#   SUPER_ADMIN_PASSWORD="p @ss #1"
# (unquoted, an inline ` #…` is treated as a comment and stripped — dotenv rule).
#SUPER_ADMIN_PASSWORD=
#SUPER_ADMIN_NAME=Super Admin
#DEFAULT_ORG_NAME=Default Organization
#DEFAULT_ORG_SLUG=default

# Config-record seeding (bootstrap one-shot only; defaults in docker-compose.yml)
# Personal (non-org) workspaces: bootstrap materializes this into app_settings.
# The absent-row code default is ENABLED — the compose default pins it OFF to
# match the reference deployment. Set true to allow personal workspaces.
#PERSONAL_WORKSPACE_ENABLED=false
# Global nav-visibility baseline (48 overrides hiding admin/analytics nav items
# from the team-manager/user/viewer org roles). Set false to skip seeding.
#SEED_NAV_BASELINE=true

# ── Operations ───────────────────────────────────────────────────────────────
# Days of local backups kept by ./backup.sh (older ones are pruned).
#BACKUP_RETENTION_DAYS=7
