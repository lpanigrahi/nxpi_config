# =============================================================================
# .env.app — runtime env_file for the `app` container (standalone Azure deploy).
#
# Copy to `.env.app` (never commit it) and fill in. This file supplies values
# the compose `environment:` block does NOT pass through — chiefly the LLM
# provider key(s). DB / Redis / auth-secret come from ./secrets/*; the public
# URL and image ref come from ./.env (Compose interpolation).
#
#   cp .env.app.example .env.app   # then edit  (./install.sh does this for you)
# =============================================================================

# --- LLM providers (set AT LEAST ONE; the app is unusable without one) --------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=

# Azure OpenAI (if using Azure-hosted models instead of/alongside the above).
# AZURE_OPENAI_DEPLOYMENTS is REQUIRED for any Azure models to appear (comma-
# separated deployment names from Azure AI Foundry).
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
# AZURE_OPENAI_DEPLOYMENTS=gpt-4o,gpt-4o-mini
# AZURE_OPENAI_API_VERSION=2025-01-01-preview        # optional

# --- File storage (optional) --------------------------------------------------
# Default is local disk on the `uploads-data` volume. To use Azure Blob
# instead, uncomment FILE_STORAGE_TYPE + the container, then EITHER the
# connection string OR account name+key (not both). NOTE: the blob container
# must already exist (the app never creates it) and its CORS must allow the
# browser origin — see the app repo's docs/deployment/azure-vm.md §C.4b.
# FILE_STORAGE_TYPE=azure
# FILE_STORAGE_AZURE_CONTAINER=neogen-uploads
#   Option A — connection string:
# FILE_STORAGE_AZURE_CONNECTION_STRING=
#   Option B — account name + key (enables direct client SAS uploads):
# FILE_STORAGE_AZURE_ACCOUNT_NAME=
# FILE_STORAGE_AZURE_ACCOUNT_KEY=
#   Optional (either option):
# FILE_STORAGE_AZURE_PUBLIC_BASE_URL=                  # CDN / custom domain
# FILE_STORAGE_AZURE_ENDPOINT_SUFFIX=core.windows.net  # for sovereign clouds

# --- Cookies / ingress mode ----------------------------------------------------
# IP-only mode (plain HTTP on the VM IP) REQUIRES this: NODE_ENV=production
# forces Secure cookies by default, and browsers refuse to store Secure
# cookies over http:// — sign-in silently loops. Explicit false disables the
# force. Domain mode (https://): leave unset (Secure stays on — do NOT set
# false).
# BETTER_AUTH_COOKIE_SECURE=false

# --- OAuth / SSO (optional) ---------------------------------------------------
# If you enable any OAuth provider, set sameSite=lax — the default "strict"
# drops the session cookie on the cross-site provider callback, breaking OAuth
# login. (Email/password login works fine on the default.)
# BETTER_AUTH_COOKIE_SAMESITE=lax
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=

# --- Other optional runtime config -------------------------------------------
# CRON_SECRET=
# EMBEDDING_PROVIDER=openai
# OTEL_EXPORTER_OTLP_ENDPOINT=
# SENTRY_DSN=
